{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "start:production": "cross-env NODE_ENV=production node ./bin/www",
    "dev": "nodemon ./bin/www",
    "test": "jest",
    "seed": "node ./db/seed.js",
    "migrate": "node ./run_all_migrations.js",
    "create-demo": "node ./create_demo_users.js",
    "test-settings": "node ./test_all_settings.js",
    "update-deps": "npx npm-check-updates -u && npm install",
    "security-check": "npm audit --production",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.966.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "~1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "csv-parser": "^3.2.0",
    "debug": "~4.3.4",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-errors": "~2.0.0",
    "jade": "^1.9.2",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sanitize-html": "^2.17.0",
    "sib-api-v3-sdk": "^8.5.0",
    "socket.io": "^4.8.1",
    "supertest": "^7.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "sqlite3": "^5.1.7"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "maxWorkers": 1,
    "rootDir": "./",
    "modulePathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/../.vscode/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ]
  }
}
